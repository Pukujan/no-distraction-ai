{
  "manifest_version": 3,
  "name": "No Distraction AI",
  "version": "1.0.0",
  "description": "AI-powered content blocker. Tell it what to hide on any website.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>", "https://api.emailjs.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "No Distraction AI"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start",
    "all_frames": false
  }],
  "web_accessible_resources": [{
    "resources": ["dashboard.html"],
    "matches": ["<all_urls>"]
  }]
}
